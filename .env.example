# AetherHealth Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Configuration
NEXT_PUBLIC_APP_NAME=AetherHealth
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/aetherhealth_development

# AI/Healthcare APIs
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Healthcare Data APIs (if applicable)
FHIR_SERVER_URL=https://your-fhir-server.com
HEALTH_API_KEY=your_health_api_key_here

# Security & Compliance
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_hipaa_compliant_encryption_key

# Email Services
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# Development
DEBUG=true
LOG_LEVEL=info